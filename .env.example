# .env.example file
# Copy this file to .env and enter actual values.

# Langsmith Project Tracking
LANGSMITH_PROJECT=act...  # Project name to be used by LangSmith.
LANGSMITH_API_KEY=lsv2...  # LangSmith API key (must be replaced with real key)

# Google Gemini API Key - required for summarization.
# Get it from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Tavily API Key - required for web search.
# Get it from https://tavily.com/
TAVILY_API_KEY=tvly-...

# Resend API Key - required for email delivery.
# Get it from https://resend.com/
RESEND_API_KEY=re_...

# (Optional) Resend sender email address.
# Default: onboarding@resend.dev (for testing)
# For production, use a verified domain email.
# RESEND_FROM_EMAIL=summary@yourdomain.com
